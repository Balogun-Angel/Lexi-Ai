# LexiAI — Environment Variables
# Copy this file to .env and fill in values.

# Application
APP_ENV=development
APP_NAME=LexiAI

# Frontend
FRONTEND_URL=http://localhost:5173

# Backend
BACKEND_PORT=8000

# Database
DATABASE_URL=postgresql://lexiai:lexiai@localhost:5432/lexiai

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External Services (future phases)
# OPENAI_API_KEY=
